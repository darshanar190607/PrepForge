# === DATABASE ===
# PostgreSQL connection string (from Render Postgres or Neon)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# === AUTH ===
# Secret key used to sign JWT tokens — use a long random string in production
JWT_SECRET="your_super_secret_jwt_key_here"

# === AI / GROQ ===
# Groq API key for AI-powered quiz features
GROQ_API_KEY="your_groq_api_key_here"

# === GEMINI (optional) ===
GEMINI_API_KEY="your_gemini_api_key_here"

# === SERVER ===
# Render sets this automatically; 4000 is used locally
PORT=4000
NODE_ENV=production
